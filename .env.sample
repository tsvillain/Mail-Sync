# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║              Gmail Multi-Account Sync — Environment Configuration           ║
# ║                                                                              ║
# ║  HOW TO USE                                                                  ║
# ║  ─────────                                                                   ║
# ║  1. Copy this file:  cp .env.sample .env                                     ║
# ║  2. Fill in every required value (marked with ← REQUIRED)                   ║
# ║  3. Never commit .env to version control — it contains secrets               ║
# ║  4. Restart the server after any change                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ── Database ───────────────────────────────────────────────────────────────────
#
# MongoDB connection string shared by BOTH the backend server and the Next.js
# frontend (server components / API routes). This single file is the source of
# truth for both processes — no need to duplicate it in client/.env.local.
#
# Local development:  mongodb://localhost:27017/<dbname>
# Atlas (cloud):      mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>
#
# ← REQUIRED
MONGODB_URI=mongodb://localhost:27017/gmail-sync


# ── Google OAuth 2.0 Credentials ──────────────────────────────────────────────
#
# How to obtain these credentials:
#   1. Open https://console.cloud.google.com/apis/credentials
#   2. Click "Create Credentials" → "OAuth 2.0 Client ID"
#   3. Application type: Web application
#   4. Add the following under "Authorised redirect URIs":
#        http://localhost:3000/auth/callback        ← local development
#        https://your-domain.com/auth/callback      ← production
#   5. Enable the Gmail API:
#        https://console.cloud.google.com/apis/library/gmail.googleapis.com
#   6. Copy the Client ID and Client Secret shown after creation.
#
# ← REQUIRED
GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ← REQUIRED
GMAIL_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret


# ── Account Seeding (Optional — accounts are now managed via the UI) ──────────
#
# Legacy option: a comma-separated list of Gmail addresses to pre-register in
# the database when the server starts. Each address will appear in the dashboard
# as "pending" until the user completes the Google OAuth consent flow.
#
# ✅ Recommended approach: leave this empty and use the "Add Account" button
#    in the dashboard — no server restart required.
#
# Example: GMAIL_ACCOUNTS=alice@gmail.com,bob@example.com
#
GMAIL_ACCOUNTS=


# ── Server Network Configuration ──────────────────────────────────────────────
#
# BASE_URL  — The publicly reachable URL of THIS backend server.
#             Used to construct the OAuth redirect URI forwarded to Google.
#             Must exactly match one of the "Authorised redirect URIs" registered
#             in your Google Cloud OAuth client.
#
#             Development: http://localhost:<AUTH_PORT>
#             Production:  https://api.your-domain.com
#
# AUTH_PORT — TCP port the backend HTTP server binds to.
#             Change this if port 3000 is already in use on your machine.
#             If you change AUTH_PORT, update BASE_URL to match.
#
# ← REQUIRED
BASE_URL=http://localhost:3000

# ← REQUIRED
AUTH_PORT=3000


# ── Frontend URL ───────────────────────────────────────────────────────────────
#
# The URL of the Next.js dashboard application. After a successful Google OAuth
# flow, the backend redirects the user's browser here.
#
# Development: http://localhost:3001
# Production:  https://your-dashboard-domain.com
#
# ← REQUIRED
FRONTEND_URL=http://localhost:3001


# ── Sync Schedule (Cron) ───────────────────────────────────────────────────────
#
# How often the sync engine polls Gmail for new messages. Accepts a standard
# 5-field cron expression (minute  hour  day  month  weekday).
#
# If this value is missing or invalid, the server falls back to "*/5 * * * *".
#
# Examples:
#   */5 * * * *   — every 5 minutes  (aggressive — may hit Gmail API rate limits)
#   */15 * * * *  — every 15 minutes (recommended for most use cases)
#   0 * * * *     — every hour on the hour
#   0 14 * * *    — once a day at 14:00 UTC
#
# Cron syntax reference: https://crontab.guru
#
CRON_SCHEDULE=*/15 * * * *


# ── Frontend — Backend Proxy URL ──────────────────────────────────────────────
#
# Base URL of this backend server as seen by the Next.js process.
# next.config.ts uses this to proxy /api/server/* requests from the browser to
# the backend, keeping the backend address hidden from the client.
#
# IMPORTANT: next.config.ts reads this variable from the OS environment at
# startup (before envDir is applied), so for local dev you can either:
#   a) Export it in your shell: export SERVER_URL=http://localhost:3000
#   b) Rely on the built-in fallback (http://localhost:3000) — works out of the box.
# In Docker, docker-compose.yml injects this directly via `environment:`.
#
# Development: http://localhost:3000
# Production:  https://api.your-domain.com
#
# ← REQUIRED
SERVER_URL=http://localhost:3000


# ── Frontend — UI Password Protection (Optional) ──────────────────────────────
#
# Uncomment and set a value to password-protect the entire dashboard.
# Every visitor will be prompted for this password before accessing any page.
# Leave commented out (or empty) to allow unrestricted access — suitable for
# local development or private-network deployments.
#
# Generate a strong value:  openssl rand -base64 32
#
# AUTH_PASSWORD=replace-with-a-strong-random-secret


# ── Debug Logging ─────────────────────────────────────────────────────────────
#
# Set to "1" to enable verbose debug-level logs in the server console.
# Useful during development to trace OAuth flows, sync steps, and DB queries.
# Leave empty or unset in production to avoid log noise.
#
# DEBUG=1
